# Conexão direta ao Postgres (Settings → Database → Connection string → URI)
# Necessário para aplicar migrations: bun run db:schema  ou  bun run db:setup
# Senha do banco: Dashboard → Settings → Database → Reset database password
SUPABASE_DB_PASSWORD="sua-senha-do-postgres"
DATABASE_URL="postgresql://postgres.jglzghujpxbakqqmmple:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Usuário master (único admin com acesso total)
MASTER_EMAIL="carine@dracarinecassol.com.br"
MASTER_PASSWORD="sua-senha-master"
MASTER_NAME="Dra. Carine Cassol"

# Chave para criptografar certificados A1 (.pfx) no servidor — use uma string longa e aleatória
CERTIFICATE_ENCRYPTION_KEY="gere-uma-chave-secreta-longa-aqui"

# SafeID Integração (certificado em nuvem) — cadastre em https://www.safeweb.com.br/produtos/safeidintegracao
SAFEID_CLIENT_ID="seu-client-id"
SAFEID_CLIENT_SECRET="seu-client-secret"
# URL oficial da API PSC SafeWeb — https://pscsafeweb.safewebpss.com.br/docs/
SAFEID_API_BASE_URL="https://pscsafeweb.safewebpss.com.br/Service/Microservice/OAuth/api/v0/oauth"
# Uma ou mais URLs (separadas por vírgula) — cada uma deve estar cadastrada no painel SafeID Integração
SAFEID_REDIRECT_URI="http://localhost:8080/professional/safeid/callback"

# Migração de dados do Lovable Cloud (opcional — só se quiser copiar dados existentes)
OLD_SUPABASE_URL="https://gcuitpaytezzgvismxqg.supabase.co"
OLD_SUPABASE_PUBLISHABLE_KEY=""
OLD_SUPABASE_SERVICE_ROLE_KEY=""
