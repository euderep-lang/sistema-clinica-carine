# Supabase (projeto próprio)
# Dashboard: https://supabase.com/dashboard/project/jglzghujpxbakqqmmple/settings/api
SUPABASE_PROJECT_ID="jglzghujpxbakqqmmple"
SUPABASE_URL="https://jglzghujpxbakqqmmple.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sua-anon-key-aqui"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key-aqui"

# Vite (mesmos valores para o client)
VITE_SUPABASE_PROJECT_ID="jglzghujpxbakqqmmple"
VITE_SUPABASE_URL="https://jglzghujpxbakqqmmple.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-aqui"

# Conexão direta ao Postgres (Settings → Database → Connection string → URI)
# Necessário para aplicar migrations: bun run db:schema  ou  bun run db:setup
# Senha do banco: Dashboard → Settings → Database → Reset database password
SUPABASE_DB_PASSWORD="sua-senha-do-postgres"
DATABASE_URL="postgresql://postgres.jglzghujpxbakqqmmple:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Usuário master (único admin com acesso total)
MASTER_EMAIL="carine@dracarinecassol.com.br"
MASTER_PASSWORD="sua-senha-master"
MASTER_NAME="Dra. Carine Cassol"

# Chave para criptografar certificados A1 (.pfx) no servidor — use uma string longa e aleatória
CERTIFICATE_ENCRYPTION_KEY="gere-uma-chave-secreta-longa-aqui"

# SafeID Integração (certificado em nuvem) — cadastre em https://www.safeweb.com.br/produtos/safeidintegracao
SAFEID_CLIENT_ID="seu-client-id"
SAFEID_CLIENT_SECRET="seu-client-secret"
# URL oficial da API PSC SafeWeb — https://pscsafeweb.safewebpss.com.br/docs/
SAFEID_API_BASE_URL="https://pscsafeweb.safewebpss.com.br/Service/Microservice/OAuth/api/v0/oauth"
# Uma ou mais URLs (separadas por vírgula) — cada uma deve estar cadastrada no painel SafeID Integração
SAFEID_REDIRECT_URI="http://localhost:8080/professional/safeid/callback"

# WhatsApp CRM — provedor: zapi (recomendado p/ começar) ou meta
WHATSAPP_PROVIDER="zapi"

# Z-API — https://www.z-api.io/ (instância + QR code no celular)
ZAPI_INSTANCE_ID="sua-instancia"
ZAPI_TOKEN="seu-token-da-instancia"
ZAPI_CLIENT_TOKEN="obrigatorio-se-token-de-seguranca-estiver-ativo"

# Meta WhatsApp Cloud API (alternativa oficial)
# WHATSAPP_PROVIDER="meta"
# WHATSAPP_ACCESS_TOKEN="seu-token-permanente"
# WHATSAPP_PHONE_NUMBER_ID="id-do-numero-no-gerenciador-whatsapp"
# WHATSAPP_BUSINESS_ACCOUNT_ID="id-da-conta-waba"
# WHATSAPP_WEBHOOK_VERIFY_TOKEN="token-que-voce-escolhe-para-verificacao"
# WHATSAPP_APP_SECRET="app-secret-do-meta-developers"

# Instagram + Messenger (Meta) — inbox unificado no CRM (WhatsApp pode continuar na Z-API)
# META_PAGE_ID="id-da-pagina-facebook-vinculada"
# META_PAGE_ACCESS_TOKEN="token-da-pagina-com-permissoes-messaging"

# Webhook (Z-API e Meta): https://sistema-clinicos.vercel.app/api/whatsapp/webhook
# Diagnóstico: https://sistema-clinicos.vercel.app/api/whatsapp/webhook-status
#
# Vercel (Production) — além das VITE_*, o servidor precisa destas (Settings → Environment Variables):
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, WHATSAPP_PROVIDER, ZAPI_INSTANCE_ID, ZAPI_TOKEN, ZAPI_CLIENT_TOKEN
#
# Cron de follow-ups automáticos (Vercel envia Authorization: Bearer <CRON_SECRET>)
# CRON_SECRET="gere-uma-string-longa-e-aleatoria"

# URL pública do app (links NPS, pré-cadastro)
# PUBLIC_APP_URL="https://sistema-clinicos.vercel.app"

# IA (CRM funil, resumo de prontuário, exames) — servidor apenas, NÃO use VITE_
# Local: cole em .env na raiz do projeto e reinicie o servidor (bun run dev)
# Vercel: Project → Settings → Environment Variables → OPENAI_API_KEY (Production + Preview)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Monitoramento (opcional)
# VITE_SENTRY_DSN="https://...@sentry.io/..."

# Migração de dados do Lovable Cloud (opcional — só se quiser copiar dados existentes)
OLD_SUPABASE_URL="https://gcuitpaytezzgvismxqg.supabase.co"
OLD_SUPABASE_PUBLISHABLE_KEY=""
OLD_SUPABASE_SERVICE_ROLE_KEY=""
