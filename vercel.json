{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "bun install --frozen-lockfile",
  "buildCommand": "bun run build",
  "crons": [
    {
      "path": "/api/cron/wa-follow-ups",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/siteclinica",
      "destination": "/siteclinica/index.html"
    }
  ]
}
